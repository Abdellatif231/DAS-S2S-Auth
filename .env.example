# JWT Configuration for Service-to-Service Authentication

# Shared secret for JWT verification (HS256)
# In production: Use RS256 with public/private key pair instead
# This MUST match the secret used by auth-service to sign tokens
JWT_SECRET=your-super-secret-key-change-this-in-production

# Expected JWT issuer (who mints the tokens)
# Should match what auth-service puts in the 'iss' claim
JWT_ISSUER=auth-service

# Expected JWT audience (who the token is for)
# Should be this service's identifier
JWT_AUDIENCE=das
